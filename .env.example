# ===== Application =====
APP_NAME_CN=中国电力工程企业项目经营管理平台
APP_NAME_EN=Power Engineering ERP & Project Management Platform
DEBUG=true

# ===== Security =====
# IMPORTANT: replace with a long random string in production
SECRET_KEY=please-change-this-to-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=power_engineering_erp
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== MinIO (placeholder, file upload not implemented in this phase) =====
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=minio:9000

# ===== CORS =====
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
